---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CrossLinksSection from '../components/CrossLinksSection.astro';
import ContactCTA from '../components/ContactCTA.astro';
import FaqSection from '../components/FaqSection.astro';
import { getPageContext, reader } from '../utils/reader';
import { resolveImage, resolveImageUrl } from '../utils/images';
import { splitParagraphs, splitLines } from '../utils/strings';
import { buildServicePageSchemas } from '../utils/schema';

const page = await reader.singletons.apresMidiCouture.read();
if (!page) throw new Error('Un après-midi couture content not found');

const { settings, siteUrl } = await getPageContext(Astro.site);

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const resolvedCover = await resolveImage(page.coverImage, coverGlob);
const ogImage = await resolveImageUrl(page.coverImage, coverGlob, Astro.site);

const faqItems = page.faqItems ?? [];
const schemas = buildServicePageSchemas({
  title: page.title,
  seoDescription: page.seoDescription,
  pageUrl: new URL(Astro.url.pathname, Astro.site).toString(),
  siteUrl,
  settings,
  offers: page.schemaOffers ?? [],
  faqItems,
});

const audienceItems = page.audienceItems ?? [];
---

<BaseLayout title={page.title} description={page.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemas).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={page.title} subtitle={page.subtitle} coverImage={resolvedCover ?? undefined} altText={page.coverImageAlt ?? undefined} />

  <!-- 2. Introduction + Key info -->
  {page.introduction && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)]">{page.introduction}</p>
        {(page.price || page.duration || page.location) && (
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            {page.price && (
              <div class="px-5 py-3 rounded-xl bg-[var(--color-bg-accent)] text-center">
                <p class="heading-font text-2xl font-bold text-[var(--color-button)]">{page.price}</p>
                {page.priceLabel && <p class="text-xs text-[var(--color-text-light)]">{page.priceLabel}</p>}
              </div>
            )}
            {page.duration && (
              <div class="px-5 py-3 rounded-xl bg-[var(--color-bg-accent)] text-center">
                <p class="heading-font text-2xl font-bold text-[var(--color-heading)]">{page.duration}</p>
                {page.durationLabel && <p class="text-xs text-[var(--color-text-light)]">{page.durationLabel}</p>}
              </div>
            )}
            {page.location && (
              <div class="px-5 py-3 rounded-xl bg-[var(--color-bg-accent)] text-center">
                <p class="heading-font text-2xl font-bold text-[var(--color-heading)]">{page.location}</p>
                {page.locationLabel && <p class="text-xs text-[var(--color-text-light)]">{page.locationLabel}</p>}
              </div>
            )}
          </div>
        )}
        <ContactCTA label={page.ctaLabel} />
      </div>
    </section>
  )}

  <!-- 3. Description + Audience -->
  {(page.description || audienceItems.length > 0) && (
    <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4">
        {page.description && (
          <div class="mb-12">
            {page.descriptionTitle && (
              <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-6">
                {page.descriptionTitle}
              </h2>
            )}
            <div class="prose max-w-none">
              {splitParagraphs(page.description).map((para) => (
                <p>{para}</p>
              ))}
            </div>
          </div>
        )}
        {audienceItems.length > 0 && (
          <div>
            {page.audienceTitle && (
              <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-6">
                {page.audienceTitle}
              </h2>
            )}
            <ul class="space-y-3">
              {audienceItems.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 text-[var(--color-button)]">&#10003;</span>
                  <span class="text-[var(--color-text)]">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- 4. Dates -->
  {page.dates && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4">
        {page.datesTitle && (
          <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-8">
            {page.datesTitle}
          </h2>
        )}
        <div class="max-w-md mx-auto p-6 rounded-xl bg-[var(--color-bg-accent)]">
          <div class="space-y-2 text-center">
            {splitLines(page.dates).map((line) => (
              <p class="text-[var(--color-text)] font-medium">{line}</p>
            ))}
          </div>
          {page.datesNote && (
            <p class="mt-4 text-sm text-[var(--color-text-light)] italic text-center">{page.datesNote}</p>
          )}
        </div>
        <ContactCTA label={page.ctaLabel} />
      </div>
    </section>
  )}

  <!-- 5. FAQ -->
  <FaqSection title={page.faqSectionTitle} items={faqItems} ctaLabel={page.ctaLabel} />

  <!-- 6. Cross-links -->
  {page.crossLinksText && (
    <CrossLinksSection text={page.crossLinksText} excludeHref="/un-apres-midi-couture" />
  )}
</BaseLayout>
