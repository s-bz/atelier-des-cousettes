---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { getPageContext, reader } from '../../utils/reader';
import { renderMarkdoc } from '../../utils/markdoc-components';
import { resolveImage } from '../../utils/images';
import { formatFrenchDate } from '../../utils/strings';
import { filterPublishedPosts } from '../../utils/blog';
import { buildBreadcrumbSchema } from '../../utils/schema';

export async function getStaticPaths() {
  const posts = await reader.collections.blog.all();
  return filterPublishedPosts(posts).map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await reader.collections.blog.read(slug!, { resolveLinkedFiles: true });
if (!post) return Astro.redirect('/blog');

// SECURITY: Markdoc HTML is rendered with set:html (no sanitisation).
// This is safe because content is authored by a single trusted editor via Keystatic.
// If adding untrusted editors, add sanitisation (e.g. sanitize-html) here.
const renderedContent = renderMarkdoc(post.content.node);
const { settings, siteUrl } = await getPageContext(Astro.site);

const formattedDate = post.publishDate ? formatFrenchDate(post.publishDate) : '';

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const resolvedCover = await resolveImage(post.coverImage, coverGlob);
const ogImage = resolvedCover ? new URL(resolvedCover.src, Astro.site).toString() : undefined;

const blogIndex = await reader.singletons.blogIndex.read();
const authorName = settings?.authorName ?? 'L\'Atelier des Cousettes';
const dateModified = post.lastModified || post.publishDate;

// Related articles: pick up to 3 other published posts (most recent first)
const allPosts = await reader.collections.blog.all();
const relatedPosts = filterPublishedPosts(allPosts)
  .filter((p) => p.slug !== slug)
  .sort((a, b) => new Date(b.entry.publishDate).getTime() - new Date(a.entry.publishDate).getTime())
  .slice(0, 3);
---

<BaseLayout title={post.title} description={post.seoDescription} ogImage={ogImage} ogType="article" articlePublishedTime={post.publishDate ?? undefined} articleAuthor={authorName}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      buildBreadcrumbSchema([
        { name: 'Accueil', url: siteUrl },
        { name: 'Blog couture', url: `${siteUrl}/blog` },
        { name: post.title },
      ]),
      {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": post.title,
        "description": post.seoDescription,
        "url": new URL(Astro.url.pathname, Astro.site).toString(),
        "datePublished": post.publishDate,
        "dateModified": dateModified,
        "author": {
          "@type": "Person",
          "name": authorName,
          "jobTitle": settings?.authorJobTitle,
          "url": `${siteUrl}/la-couturiere/`
        },
        "publisher": {
          "@type": "Organization",
          "name": settings?.siteName,
          "url": siteUrl
        },
        "isPartOf": { "@id": `${siteUrl}/#website` },
        ...(ogImage ? { "image": ogImage } : {})
      }
    ]).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={post.title} coverImage={resolvedCover ?? undefined} altText={post.coverImageAlt || undefined} />

  <!-- 2. Article content -->
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4">
      {formattedDate && (
        <div class="flex items-center gap-2 text-sm text-[var(--color-text-light)] mb-8">
          <time datetime={post.publishDate ?? ''}>{formattedDate}</time>
          <span>&middot;</span>
          <span>Par {authorName}</span>
        </div>
      )}

      <div class="prose overflow-visible">
        <Fragment set:html={renderedContent} />
      </div>
    </div>
  </section>

  <!-- 3. Related articles -->
  {relatedPosts.length > 0 && (
    <section class="py-16 md:py-20">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-8">
          Articles connexes
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map((related) => (
            <a href={`/blog/${related.slug}`} class="block bg-white rounded-[var(--radius-xl)] shadow-md p-5 hover:shadow-lg transition-shadow">
              <h3 class="text-base font-bold text-[var(--color-heading)] mb-2">
                {related.entry.title}
              </h3>
              <p class="text-sm text-[var(--color-text-light)] line-clamp-3">{related.entry.seoDescription}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 4. CTA + Back to blog -->
  <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      {blogIndex?.ctaText && (
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)] mb-2">{blogIndex.ctaText}</p>
      )}
      <ContactCTA label={blogIndex?.ctaLabel} />
      <a href="/blog" class="mt-6 inline-block text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors">
        &larr; {blogIndex?.backToListLabel}
      </a>
    </div>
  </section>
</BaseLayout>
