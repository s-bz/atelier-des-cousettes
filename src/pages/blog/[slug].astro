---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Markdoc from '@markdoc/markdoc';
import { reader } from '../../utils/reader';
import { resolveImageUrl } from '../../utils/images';
import { formatFrenchDate } from '../../utils/strings';
import { filterPublishedPosts } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await reader.collections.blog.all();
  return filterPublishedPosts(posts).map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await reader.collections.blog.read(slug!, { resolveLinkedFiles: true });
if (!post) return Astro.redirect('/blog');

// SECURITY: Markdoc HTML is rendered with set:html (no sanitisation).
// This is safe because content is authored by a single trusted editor via Keystatic.
// If adding untrusted editors, add sanitisation (e.g. sanitize-html) here.
const transformed = post.content.node ? Markdoc.transform(post.content.node) : null;
const renderedContent = transformed ? Markdoc.renderers.html(transformed) : '';
const siteUrl = Astro.site?.origin ?? '';
const settings = await reader.singletons.siteSettings.read();

const formattedDate = post.publishDate ? formatFrenchDate(post.publishDate) : '';

const blogGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/blog/**/*.{jpg,jpeg,png,webp}');
const ogImage = await resolveImageUrl(post.coverImage, blogGlob, Astro.site);

const blogIndex = await reader.singletons.blogIndex.read();
const authorName = settings?.authorName ?? 'L\'Atelier des Cousettes';
---

<BaseLayout title={post.title} description={post.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
          { "@type": "ListItem", "position": 2, "name": "Blog couture", "item": `${siteUrl}/blog` },
          { "@type": "ListItem", "position": 3, "name": post.title }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": post.title,
        "description": post.seoDescription,
        "url": new URL(Astro.url.pathname, Astro.site).toString(),
        "datePublished": post.publishDate,
        "dateModified": post.publishDate,
        "author": {
          "@type": "Person",
          "name": authorName,
          "jobTitle": settings?.authorJobTitle,
          "url": `${siteUrl}/la-couturiere/`
        },
        "publisher": {
          "@type": "Organization",
          "name": settings?.siteName,
          "url": siteUrl
        },
        "isPartOf": { "@id": `${siteUrl}/#website` },
        ...(ogImage ? { "image": ogImage } : {})
      }
    ]).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={post.title} coverImage={post.coverImage || undefined} altText={post.coverImageAlt || undefined} />

  <!-- 2. Article content -->
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4">
      {formattedDate && (
        <div class="flex items-center gap-2 text-sm text-[var(--color-text-light)] mb-8">
          <time datetime={post.publishDate ?? ''}>{formattedDate}</time>
          <span>&middot;</span>
          <span>Par {authorName}</span>
        </div>
      )}

      <div class="prose overflow-visible">
        <Fragment set:html={renderedContent} />
      </div>
    </div>
  </section>

  <!-- 3. CTA + Back to blog -->
  <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      {blogIndex?.ctaText && (
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)] mb-2">{blogIndex.ctaText}</p>
      )}
      <ContactCTA label={blogIndex?.ctaLabel || undefined} />
      <a href="/blog" class="mt-6 inline-block text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors">
        &larr; Tous les articles
      </a>
    </div>
  </section>
</BaseLayout>
