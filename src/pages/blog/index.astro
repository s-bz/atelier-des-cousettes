---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import BlogCard from '../../components/BlogCard.astro';
import IntroSection from '../../components/IntroSection.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { getPageContext, reader } from '../../utils/reader';
import { resolveImage, resolveImageUrl } from '../../utils/images';
import { filterPublishedPosts } from '../../utils/blog';
import { buildPageSchemas } from '../../utils/schema';

const page = await reader.singletons.blogIndex.read();
if (!page) throw new Error('Blog index content not found');

const posts = await reader.collections.blog.all();
const sortedPosts = filterPublishedPosts(posts)
  .sort((a, b) => new Date(b.entry.publishDate).getTime() - new Date(a.entry.publishDate).getTime());

const { settings, siteUrl } = await getPageContext(Astro.site);

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const resolvedCover = await resolveImage(page.coverImage, coverGlob);
const ogImage = await resolveImageUrl(page.coverImage, coverGlob, Astro.site);
const pageUrl = new URL('/blog/', Astro.site).toString();

const schemas = buildPageSchemas({
  title: page.title,
  seoDescription: page.seoDescription,
  pageUrl,
  siteUrl,
  settings,
});
---

<BaseLayout title={page.title} description={page.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      ...schemas,
      {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": `${page.title} — ${settings?.siteName}`,
        "description": page.seoDescription,
        "url": pageUrl,
        "isPartOf": { "@id": `${siteUrl}/#website` },
        "mainEntity": sortedPosts.map((post) => ({
          "@type": "BlogPosting",
          "headline": post.entry.title,
          "url": `${siteUrl}/blog/${post.slug}/`,
          "datePublished": post.entry.publishDate,
        })),
      }
    ]).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={page.title} subtitle={page.subtitle} coverImage={resolvedCover ?? undefined} altText={page.coverImageAlt} />

  <!-- 2. Introduction -->
  {page.introduction && (
    <IntroSection text={page.introduction} ctaLabel={page.ctaLabel} />
  )}

  <!-- 3. Articles -->
  <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      {sortedPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sortedPosts.map((post) => (
            <BlogCard
              title={post.entry.title}
              slug={post.slug}
              publishDate={post.entry.publishDate}
              description={post.entry.seoDescription}
              readMoreLabel={page.readMoreLabel ?? ''}
            />
          ))}
        </div>
      ) : (
        <p class="text-center text-[var(--color-text-light)]">{page.emptyStateText}</p>
      )}
    </div>
  </section>

  <!-- 4. CTA -->
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      {page.ctaText && (
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)] mb-2">{page.ctaText}</p>
      )}
      <ContactCTA label={page.ctaLabel} />
    </div>
  </section>
</BaseLayout>
