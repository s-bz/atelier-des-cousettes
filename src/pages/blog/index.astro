---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import BlogCard from '../../components/BlogCard.astro';
import { reader } from '../../utils/reader';
import { resolveImageUrl } from '../../utils/images';

const page = await reader.singletons.blogIndex.read();
if (!page) throw new Error('Blog index content not found');

const posts = await reader.collections.blog.all();

const sortedPosts = posts
  .filter((post): post is typeof post & { entry: { publishDate: string } } =>
    Boolean(post.entry.publishDate),
  )
  .sort((a, b) => new Date(b.entry.publishDate).getTime() - new Date(a.entry.publishDate).getTime());

const siteUrl = Astro.site?.origin;
const settings = await reader.singletons.siteSettings.read();

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const ogImage = await resolveImageUrl(page.coverImage, coverGlob, Astro.site);
---

<BaseLayout
  title={page.title}
  description={page.seoDescription}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
          { "@type": "ListItem", "position": 2, "name": page.title }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": `${page.title} — ${settings?.siteName}`,
        "description": page.seoDescription,
        "url": new URL('/blog', Astro.site).toString(),
        "isPartOf": { "@id": `${siteUrl}/#website` },
        "author": {
          "@type": "Person",
          "name": settings?.authorName,
          "jobTitle": settings?.authorJobTitle
        }
      }
    ]).replace(/<\//g, '<\\/')} />
  </Fragment>

  <Hero
    title={page.title}
    subtitle={page.subtitle}
    coverImage={page.coverImage || undefined}
    altText={page.coverImageAlt}
  />

  <div class="max-w-3xl mx-auto px-4 pb-16">
    {sortedPosts.length > 0 ? (
      <div class="grid gap-6">
        {sortedPosts.map((post) => (
          <BlogCard
            title={post.entry.title}
            slug={post.slug}
            publishDate={post.entry.publishDate}
            description={post.entry.seoDescription}
          />
        ))}
      </div>
    ) : (
      <p class="text-center text-[var(--color-text-light)]">Aucun article pour le moment.</p>
    )}
  </div>
</BaseLayout>
