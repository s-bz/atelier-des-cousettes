---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import IntroSection from '../components/IntroSection.astro';
import CrossLinksSection from '../components/CrossLinksSection.astro';
import { getPageContext, reader } from '../utils/reader';
import { resolveImage, resolveImageUrl } from '../utils/images';
import { buildPageSchemas } from '../utils/schema';

const page = await reader.singletons.mesCreations.read();
if (!page) throw new Error('Mes créations content not found');

const { settings, siteUrl } = await getPageContext(Astro.site);

const creations = await reader.collections.creations.all();
const sorted = creations.sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0));

const creationGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/creations/*.{jpg,jpeg,png,webp}');
const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const resolvedCover = await resolveImage(page.coverImage, coverGlob);
const ogImage = await resolveImageUrl(page.coverImage, coverGlob, Astro.site);

// Resolve gallery images once — used for both schema and template
const allGalleryItems = await Promise.all(sorted.map(async (creation) => {
  const src = await resolveImage(creation.entry.image, creationGlob);
  return {
    src,
    alt: creation.entry.imageAlt || creation.entry.title,
    title: creation.entry.title,
  };
}));
// Only items with resolved images for schema
const schemaImages = allGalleryItems
  .filter((item): item is typeof item & { src: ImageMetadata } => item.src !== null)
  .map(item => {
    const url = new URL(item.src.src, Astro.site).toString();
    return {
      "@type": "ImageObject" as const,
      "name": item.title,
      "contentUrl": url,
      "thumbnailUrl": url,
      "description": item.alt,
    };
  });

const schemas = buildPageSchemas({
  title: page.title,
  seoDescription: page.seoDescription,
  pageUrl: new URL(Astro.url.pathname, Astro.site).toString(),
  siteUrl,
  settings,
});
---

<BaseLayout title={page.title} description={page.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      ...schemas,
      {
        "@context": "https://schema.org",
        "@type": "ImageGallery",
        "name": page.title,
        "description": page.seoDescription,
        "url": `${siteUrl}/mes-creations/`,
        "creator": { "@id": `${siteUrl}/#organization` },
        "image": schemaImages
      }
    ]).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={page.title} subtitle={page.subtitle} coverImage={resolvedCover ?? undefined} altText={page.coverImageAlt ?? undefined} />

  <!-- 2. Introduction -->
  {page.introduction && (
    <IntroSection text={page.introduction} ctaLabel={page.ctaLabel} />
  )}

  <!-- 3. Gallery -->
  <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4">
      {page.gallerySectionTitle && (
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-10">
          {page.gallerySectionTitle}
        </h2>
      )}
      {allGalleryItems.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="gallery">
          {allGalleryItems.map((item) => (
            <div class="group">
              {item.src ? (
                <button type="button" class="gallery-item w-full focus-visible:ring-2 focus-visible:ring-[var(--color-button)] focus-visible:ring-offset-2 rounded-2xl focus:outline-none" data-src={item.src.src} data-alt={item.alt}>
                  <Image
                    src={item.src}
                    alt={item.alt}
                    class="rounded-2xl w-full h-72 object-cover group-hover:opacity-90 transition-opacity cursor-pointer"
                    format="webp"
                    quality={80}
                    widths={[320, 480, 640]}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  />
                </button>
              ) : (
                <div class="rounded-2xl w-full h-72 bg-white flex items-center justify-center">
                  <span class="text-[var(--color-text-light)]">{page.missingImageText}</span>
                </div>
              )}
              <p class="mt-3 text-center text-sm font-medium text-[var(--color-text-light)]">{item.alt}</p>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-center text-[var(--color-text-light)]">{page.emptyGalleryText}</p>
      )}
    </div>
  </section>

  <!-- 4. Cross-links -->
  {page.crossLinksText && (
    <CrossLinksSection text={page.crossLinksText} />
  )}

  <!-- Lightbox -->
  <dialog id="lightbox" class="relative p-0 bg-transparent backdrop:bg-black/80 max-w-[90vw] max-h-[90vh] m-auto overflow-visible">
    <button class="absolute -top-3 -right-3 w-10 h-10 flex items-center justify-center rounded-full bg-[var(--color-button)] text-white text-2xl leading-none z-10 hover:bg-[var(--color-button-hover)] focus-visible:ring-2 focus-visible:ring-white focus:outline-none transition-colors" aria-label="Fermer">&times;</button>
    <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] rounded-2xl block" />
  </dialog>

  <script>
    const dialog = document.getElementById('lightbox') as HTMLDialogElement;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    let lastFocused: HTMLElement | null = null;

    document.querySelectorAll('.gallery-item').forEach((item) => {
      item.addEventListener('click', () => {
        const el = item as HTMLElement;
        if (el.dataset.src && lightboxImg && dialog) {
          lastFocused = el;
          lightboxImg.src = el.dataset.src;
          lightboxImg.alt = el.dataset.alt || '';
          dialog.showModal();
          dialog.querySelector('button')?.focus();
        }
      });
    });

    dialog?.addEventListener('close', () => lastFocused?.focus());

    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    dialog?.querySelector('button')?.addEventListener('click', () => dialog.close());
  </script>
</BaseLayout>
