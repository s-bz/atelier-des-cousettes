---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { reader } from '../utils/reader';
import Markdoc from '@markdoc/markdoc';

const page = await reader.singletons.mesCreations.read();
const contentNode = page?.content ? await page.content() : null;
const transformed = contentNode ? Markdoc.transform(contentNode.node) : null;
const renderedContent = transformed ? Markdoc.renderers.html(transformed) : '';
const creations = await reader.collections.creations.all();
const sorted = creations.sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0));

// Dynamically import all creation images
const creationImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/creations/*.{jpg,jpeg,png,webp}');

async function resolveImage(img: string | null) {
  if (!img) return null;
  const filename = img.startsWith('/') ? img.split('/').pop()! : img;
  const key = `/src/assets/images/creations/${filename}`;
  const mod = await creationImages[key]?.();
  return mod?.default ?? null;
}
---

<BaseLayout title={page?.title || 'Mes créations'} description={page?.seoDescription || ''}>
  <Hero title={page?.title || 'Mes créations'} subtitle={page?.subtitle} coverImage={page?.coverImage} />

  {renderedContent && (
    <div class="max-w-3xl mx-auto px-4 prose mb-12">
      <Fragment set:html={renderedContent} />
    </div>
  )}

  <div class="max-w-5xl mx-auto px-4">
    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="gallery">
        {await Promise.all(sorted.map(async (creation) => {
          const imgSrc = await resolveImage(creation.entry.image);
          return (
            <div>
              {imgSrc ? (
                <button class="gallery-item w-full" data-src={imgSrc.src}>
                  <Image
                    src={imgSrc}
                    alt={creation.entry.imageAlt || creation.entry.title}
                    class="rounded-2xl w-full h-72 object-cover hover:opacity-90 transition-opacity cursor-pointer"
                    format="webp"
                    quality={80}
                    widths={[320, 480, 640]}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  />
                </button>
              ) : (
                <div class="rounded-2xl w-full h-72 bg-[var(--color-bg-accent)] flex items-center justify-center">
                  <span class="text-[var(--color-text-light)]">Image manquante</span>
                </div>
              )}
              <p class="mt-2 text-center text-sm text-[var(--color-text-light)]">{creation.entry.imageAlt || creation.entry.title}</p>
            </div>
          );
        }))}
      </div>
    ) : (
      <p class="text-center text-[var(--color-text-light)]">Galerie en cours de construction.</p>
    )}
  </div>

  <!-- Lightbox (uses original src from Astro's processed image) -->
  <dialog id="lightbox" class="p-0 bg-transparent backdrop:bg-black/80 max-w-[90vw] max-h-[90vh] m-auto">
    <button class="absolute top-2 right-2 text-white text-3xl leading-none z-10 hover:opacity-80" aria-label="Fermer">&times;</button>
    <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[90vh] rounded-2xl block" />
  </dialog>

  <script>
    const dialog = document.getElementById('lightbox') as HTMLDialogElement;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

    document.querySelectorAll('.gallery-item').forEach((item) => {
      item.addEventListener('click', () => {
        const src = (item as HTMLElement).dataset.src;
        if (src && lightboxImg && dialog) {
          lightboxImg.src = src;
          dialog.showModal();
        }
      });
    });

    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    dialog?.querySelector('button')?.addEventListener('click', () => dialog.close());
  </script>
</BaseLayout>
