---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { reader } from '../utils/reader';
import { resolveImage, resolveImageUrl } from '../utils/images';

const page = await reader.singletons.mesCreations.read();
if (!page) throw new Error('Mes créations content not found');

const creations = await reader.collections.creations.all();
const sorted = creations.sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0));

const creationGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/creations/*.{jpg,jpeg,png,webp}');
const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const ogImage = await resolveImageUrl(page.coverImage, coverGlob, Astro.site);

// Resolve gallery images for schema
const galleryItems = await Promise.all(sorted.map(async (creation) => {
  const imgSrc = await resolveImage(creation.entry.image, creationGlob);
  return {
    src: imgSrc,
    alt: creation.entry.imageAlt || creation.entry.title,
    title: creation.entry.title,
  };
}));
const siteUrl = Astro.site?.toString();
---

<BaseLayout title={page.title} description={page.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": Astro.site?.origin },
        { "@type": "ListItem", "position": 2, "name": page.title }
      ]
    }).replace(/<\//g, '<\\/')} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ImageGallery",
      "name": page.title,
      "description": page.seoDescription,
      "url": `${siteUrl}mes-creations/`,
      "creator": { "@id": `${siteUrl}/#organization` },
      "image": galleryItems
        .filter(item => item.src)
        .map(item => ({
          "@type": "ImageObject",
          "name": item.title,
          "contentUrl": new URL(item.src!.src, Astro.site).toString(),
          "description": item.alt
        }))
    }).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={page.title} subtitle={page.subtitle} coverImage={page.coverImage ?? undefined} altText={page.coverImageAlt ?? undefined} />

  <!-- 2. Introduction -->
  {page.introduction && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)]">{page.introduction}</p>
        <ContactCTA label={page.ctaLabel || undefined} />
      </div>
    </section>
  )}

  <!-- 3. Gallery -->
  <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4">
      {page.gallerySectionTitle && (
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-10" style="font-family: var(--font-heading);">
          {page.gallerySectionTitle}
        </h2>
      )}
      {sorted.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="gallery">
          {await Promise.all(sorted.map(async (creation) => {
            const imgSrc = await resolveImage(creation.entry.image, creationGlob);
            return (
              <div class="group">
                {imgSrc ? (
                  <button class="gallery-item w-full" data-src={imgSrc.src} data-alt={creation.entry.imageAlt || creation.entry.title}>
                    <Image
                      src={imgSrc}
                      alt={creation.entry.imageAlt || creation.entry.title}
                      class="rounded-2xl w-full h-72 object-cover group-hover:opacity-90 transition-opacity cursor-pointer"
                      format="webp"
                      quality={80}
                      widths={[320, 480, 640]}
                      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                    />
                  </button>
                ) : (
                  <div class="rounded-2xl w-full h-72 bg-white flex items-center justify-center">
                    <span class="text-[var(--color-text-light)]">Image manquante</span>
                  </div>
                )}
                <p class="mt-3 text-center text-sm font-medium text-[var(--color-text-light)]">{creation.entry.imageAlt || creation.entry.title}</p>
              </div>
            );
          }))}
        </div>
      ) : (
        <p class="text-center text-[var(--color-text-light)]">Galerie en cours de construction.</p>
      )}
    </div>
  </section>

  <!-- 4. Cross-links -->
  {page.crossLinksText && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)]">{page.crossLinksText}</p>
        <div class="mt-6 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/ateliers-reguliers" class="text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors">
            Ateliers réguliers &rarr;
          </a>
          <a href="/stages-thematiques" class="text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors">
            Stages thématiques &rarr;
          </a>
          <a href="/un-apres-midi-couture" class="text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors">
            Un après-midi couture &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Lightbox -->
  <dialog id="lightbox" class="p-0 bg-transparent backdrop:bg-black/80 max-w-[90vw] max-h-[90vh] m-auto">
    <button class="absolute top-2 right-2 text-white text-3xl leading-none z-10 hover:opacity-80" aria-label="Fermer">&times;</button>
    <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[90vh] rounded-2xl block" />
  </dialog>

  <script>
    const dialog = document.getElementById('lightbox') as HTMLDialogElement;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

    document.querySelectorAll('.gallery-item').forEach((item) => {
      item.addEventListener('click', () => {
        const el = item as HTMLElement;
        if (el.dataset.src && lightboxImg && dialog) {
          lightboxImg.src = el.dataset.src;
          lightboxImg.alt = el.dataset.alt || '';
          dialog.showModal();
        }
      });
    });

    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    dialog?.querySelector('button')?.addEventListener('click', () => dialog.close());
  </script>
</BaseLayout>
