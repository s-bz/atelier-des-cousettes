---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { reader } from '../utils/reader';
import { resolveImage, resolveImageUrl } from '../utils/images';
import Markdoc from '@markdoc/markdoc';

const homepage = await reader.singletons.homepage.read();
const settings = await reader.singletons.siteSettings.read();

if (!homepage) throw new Error('Homepage content not found');

const contentNode = homepage.content ? await homepage.content() : null;
const transformed = contentNode ? Markdoc.transform(contentNode.node) : null;
const renderedContent = transformed ? Markdoc.renderers.html(transformed) : '';

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const ogImage = await resolveImageUrl(homepage.coverImage, coverGlob, Astro.site);

const phone = settings?.phones?.[0]?.replace(/[.\s]/g, '');
const phoneIntl = phone ? `+33${phone.slice(1)}` : undefined;

const siteUrl = Astro.site?.origin;

const homepageGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/homepage/**/*.{jpg,jpeg,png,webp}');
const resolvedHeroImg = await resolveImage(homepage.heroImage, homepageGlob);

const resolvedCards = await Promise.all(
  (homepage.serviceCards ?? []).map(async (card) => ({
    ...card,
    resolvedImage: await resolveImage(card.image, homepageGlob),
  })),
);
---

<BaseLayout title={homepage.title} description={homepage.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "@id": `${siteUrl}/#organization`,
        "name": homepage.title,
        "description": homepage.seoDescription,
        "url": siteUrl,
        "email": settings?.email,
        "telephone": phoneIntl,
        "image": ogImage,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": settings?.streetAddress,
          "addressLocality": settings?.addressLocality,
          "postalCode": settings?.postalCode,
          "addressRegion": settings?.addressRegion,
          "addressCountry": "FR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 43.4833,
          "longitude": 2.3667
        },
        "areaServed": [
          { "@type": "City", "name": "Verdalle" },
          { "@type": "City", "name": "Revel" },
          { "@type": "AdministrativeArea", "name": "Tarn" }
        ],
        "priceRange": "25€–90€",
        "sameAs": settings?.facebookUrl ? [settings.facebookUrl] : [],
        "founder": {
          "@type": "Person",
          "name": "Isabelle Bultez",
          "jobTitle": "Couturière diplômée CAP",
          "url": `${siteUrl}/la-couturiere/`,
          "knowsAbout": ["couture", "patronage", "surjeteuse", "machine à coudre"],
          "sameAs": settings?.facebookUrl ? [settings.facebookUrl] : []
        },
        "openingHoursSpecification": [
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "14:00", "closes": "17:00" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "14:00", "closes": "19:30" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:30", "closes": "17:00" }
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Cours et stages de couture",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ateliers réguliers", "url": `${siteUrl}/ateliers-reguliers/` } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Stages thématiques", "url": `${siteUrl}/stages-thematiques/` } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Après-midi couture", "url": `${siteUrl}/un-apres-midi-couture/` } }
          ]
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        "name": homepage.title,
        "url": siteUrl,
        "publisher": { "@id": `${siteUrl}/#organization` },
        "inLanguage": "fr"
      }
    ]).replace(/<\//g, '<\\/')} />
  </Fragment>
  <Hero title={homepage.title} subtitle={homepage.subtitle} coverImage={homepage.coverImage ?? undefined} />

  <div class="max-w-3xl mx-auto px-4">
    <!-- Image hero -->
    {resolvedHeroImg && (
      <section class="mb-12">
        <Image src={resolvedHeroImg} alt={homepage.heroImageAlt || homepage.title} class="rounded-2xl w-full h-auto object-cover" format="webp" quality={80} />
      </section>
    )}

    <!-- Content from Keystatic -->
    <section class="mb-12 prose max-w-none">
      <Fragment set:html={renderedContent} />
    </section>

    <!-- Vidéo -->
    {homepage.youtubeVideoId && (
      <section class="mb-8">
        <YouTubeEmbed videoId={homepage.youtubeVideoId} title={homepage.title} />
        {homepage.youtubeCredit && (
          <p class="mt-2 text-sm text-center text-[var(--color-text-light)] italic">
            {homepage.youtubeCredit}
          </p>
        )}
      </section>
    )}

    <!-- Cartes services (depuis Keystatic) -->
    {resolvedCards.length > 0 && (
      <section class="mb-12">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {resolvedCards.map((card) => (
            <a href={card.href} class="group">
              {card.resolvedImage && (
                <Image src={card.resolvedImage} alt={card.imageAlt || card.label} class="rounded-2xl w-full h-64 object-cover group-hover:opacity-90 transition-opacity" format="webp" quality={80} widths={[320, 480]} sizes="(max-width: 640px) 100vw, 33vw" />
              )}
              <p class="mt-2 text-center text-sm font-medium text-[var(--color-heading)]">{card.label}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <ContactCTA label={homepage.ctaLabel || undefined} />
  </div>
</BaseLayout>
