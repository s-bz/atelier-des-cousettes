---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { reader } from '../utils/reader';
import Markdoc from '@markdoc/markdoc';

import heroImg from '../assets/images/homepage/aaaaa.jpg';
import img011 from '../assets/images/homepage/011.jpg';
import imgSac from '../assets/images/homepage/sac.jpg';
import img002 from '../assets/images/homepage/002.jpg';

const homepage = await reader.singletons.homepage.read();
const settings = await reader.singletons.siteSettings.read();

if (!homepage) throw new Error('Homepage content not found');

const contentNode = homepage.content ? await homepage.content() : null;
const transformed = contentNode ? Markdoc.transform(contentNode.node) : null;
const renderedContent = transformed ? Markdoc.renderers.html(transformed) : '';

// Resolve cover image for OG
const coverImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const coverImagePath = homepage.coverImage
  ? coverImages[homepage.coverImage]
    ? homepage.coverImage
    : Object.keys(coverImages).find(path => path.endsWith(`/${homepage.coverImage}`))
  : undefined;
const resolvedCover = coverImagePath ? await coverImages[coverImagePath]?.() : null;
const ogImage = resolvedCover ? new URL(resolvedCover.default.src, Astro.site).toString() : undefined;

const phone = settings?.phones?.[0]?.replace(/[.\s]/g, '');
const phoneIntl = phone ? `+33${phone.slice(1)}` : undefined;
---

<BaseLayout title={homepage.title} description={homepage.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "@id": `${Astro.site}#organization`,
        "name": homepage.title,
        "description": homepage.seoDescription,
        "url": Astro.site?.toString(),
        "email": settings?.email,
        "telephone": phoneIntl,
        "image": ogImage,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "118 lieu dit En Rivals",
          "addressLocality": "Verdalle",
          "postalCode": "81110",
          "addressRegion": "Tarn",
          "addressCountry": "FR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 43.4833,
          "longitude": 2.3667
        },
        "areaServed": [
          { "@type": "City", "name": "Verdalle" },
          { "@type": "City", "name": "Revel" },
          { "@type": "AdministrativeArea", "name": "Tarn" }
        ],
        "priceRange": "25€–90€",
        "sameAs": settings?.facebookUrl ? [settings.facebookUrl] : [],
        "founder": {
          "@type": "Person",
          "name": "Isabelle Bultez",
          "jobTitle": "Couturière diplômée CAP"
        },
        "openingHoursSpecification": [
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "14:00", "closes": "17:00" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "14:00", "closes": "19:30" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:30", "closes": "17:00" }
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Cours et stages de couture",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ateliers réguliers", "url": `${Astro.site}ateliers-reguliers/` } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Stages thématiques", "url": `${Astro.site}stages-thematiques/` } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Après-midi couture", "url": `${Astro.site}un-apres-midi-couture/` } }
          ]
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": `${Astro.site}#website`,
        "name": homepage.title,
        "url": Astro.site?.toString(),
        "publisher": { "@id": `${Astro.site}#organization` },
        "inLanguage": "fr"
      }
    ]).replace(/<\//g, '<\\/')} />
  </Fragment>
  <Hero title={homepage.title} subtitle={homepage.subtitle} coverImage={homepage.coverImage ?? undefined} />

  <div class="max-w-3xl mx-auto px-4">
    <!-- Image hero -->
    <section class="mb-12">
      <Image src={heroImg} alt={homepage.title} class="rounded-2xl w-full h-auto object-cover" format="webp" quality={80} />
    </section>

    <!-- Content from Keystatic -->
    <section class="mb-12 prose max-w-none">
      <Fragment set:html={renderedContent} />
    </section>

    <!-- Vidéo -->
    {homepage.youtubeVideoId && (
      <section class="mb-8">
        <YouTubeEmbed videoId={homepage.youtubeVideoId} title={homepage.title} />
        {homepage.youtubeCredit && (
          <p class="mt-2 text-sm text-center text-[var(--color-text-light)] italic">
            {homepage.youtubeCredit}
          </p>
        )}
      </section>
    )}

    <!-- Images avec liens -->
    <section class="mb-12">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <a href="/ateliers-reguliers" class="group">
          <Image src={img011} alt="Ateliers réguliers" class="rounded-2xl w-full h-64 object-cover group-hover:opacity-90 transition-opacity" format="webp" quality={80} widths={[320, 480]} sizes="(max-width: 640px) 100vw, 33vw" />
          <p class="mt-2 text-center text-sm font-medium text-[var(--color-heading)]">Ateliers réguliers</p>
        </a>
        <a href="/stages-thematiques" class="group">
          <Image src={imgSac} alt="Stages thématiques" class="rounded-2xl w-full h-64 object-cover group-hover:opacity-90 transition-opacity" format="webp" quality={80} widths={[320, 480]} sizes="(max-width: 640px) 100vw, 33vw" />
          <p class="mt-2 text-center text-sm font-medium text-[var(--color-heading)]">Stages thématiques</p>
        </a>
        <a href="/un-apres-midi-couture" class="group">
          <Image src={img002} alt="Un après midi couture" class="rounded-2xl w-full h-64 object-cover group-hover:opacity-90 transition-opacity" format="webp" quality={80} widths={[320, 480]} sizes="(max-width: 640px) 100vw, 33vw" />
          <p class="mt-2 text-center text-sm font-medium text-[var(--color-heading)]">Un après midi couture</p>
        </a>
      </div>
    </section>

    <ContactCTA />
  </div>
</BaseLayout>
