---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import DetailCard from '../components/DetailCard.astro';
import IntroSection from '../components/IntroSection.astro';
import CrossLinksSection from '../components/CrossLinksSection.astro';
import ContactCTA from '../components/ContactCTA.astro';
import FaqSection from '../components/FaqSection.astro';
import { getPageContext, reader } from '../utils/reader';
import { resolveImage, resolveImageUrl } from '../utils/images';
import { toSlug, splitParagraphs, splitLines } from '../utils/strings';
import { buildServicePageSchemas } from '../utils/schema';
import { ATELIER_GROUPS, ATELIER_GROUP_LABELS } from '../utils/ateliers';

const page = await reader.singletons.ateliersReguliers.read();
if (!page) throw new Error('Ateliers réguliers content not found');

const { settings, siteUrl } = await getPageContext(Astro.site);

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const resolvedCover = await resolveImage(page.coverImage, coverGlob);
const ogImage = await resolveImageUrl(page.coverImage, coverGlob, Astro.site);

const faqItems = page.faqItems ?? [];
const schemas = buildServicePageSchemas({
  title: page.title,
  seoDescription: page.seoDescription,
  pageUrl: new URL(Astro.url.pathname, Astro.site).toString(),
  siteUrl,
  settings,
  offers: page.schemaOffers ?? [],
  faqItems,
});

// Group creneaux
const creneaux = page.creneaux ?? [];
const groupedCreneaux = ATELIER_GROUPS
  .map((g) => ({ ...g, items: creneaux.filter((c) => c.group === g.id) }))
  .filter((g) => g.items.length > 0);

---

<BaseLayout title={page.title} description={page.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemas).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={page.title} subtitle={page.subtitle} coverImage={resolvedCover ?? undefined} altText={page.coverImageAlt ?? undefined} />

  <!-- 2. Introduction -->
  {page.introduction && (
    <IntroSection text={page.introduction} ctaLabel={page.ctaLabel} />
  )}

  <!-- 3. Quick nav + Créneau cards grouped -->
  {groupedCreneaux.length > 0 && (
    <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-6">
          {page.creneauxSectionTitle}
        </h2>

        {/* Pill navigation */}
        <nav class="flex flex-wrap justify-center gap-3 mb-10">
          {groupedCreneaux.map((g) => (
            <a
              href={`#${g.id}`}
              class="inline-block px-5 py-2 rounded-[var(--radius-button)] text-sm font-medium border-2 border-[var(--color-button)] text-[var(--color-button)] hover:bg-[var(--color-button)] hover:text-white transition-colors"
            >
              {g.label}
            </a>
          ))}
        </nav>

        {/* Cards by group */}
        {groupedCreneaux.map((g) => (
          <div id={g.id} class="scroll-mt-24 mb-12 last:mb-0">
            <h3 class="text-xl font-bold text-[var(--color-heading)] mb-6">
              {g.label}
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {g.items.map((c) => (
                <DetailCard
                  name={c.name}
                  anchorId={`detail-${toSlug(c.name)}`}
                  primaryBadge={c.price}
                  details={[`${c.day} \u00B7 ${c.time}`, c.location]}
                  note={c.note || undefined}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- 4. Créneau details -->
  {creneaux.length > 0 && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 space-y-16">
        {creneaux.map((c) => (
          <div id={`detail-${toSlug(c.name)}`} class="scroll-mt-24">
            <h2 class="text-xl md:text-2xl font-bold text-[var(--color-heading)] mb-2">
              {c.name}
              <span class="ml-2 text-base font-medium text-[var(--color-button)]">{c.day} &middot; {c.time}</span>
            </h2>
            <p class="text-sm text-[var(--color-text-light)] mb-4">{/* Keystatic types c.group as string; cast is safe because options are derived from ATELIER_GROUPS */}
            {ATELIER_GROUP_LABELS[c.group as keyof typeof ATELIER_GROUP_LABELS] || c.location}</p>
            {c.priceDetails && (
              <div class="prose mb-4">
                {splitParagraphs(c.priceDetails).map((para) => (
                  <p>{para}</p>
                ))}
              </div>
            )}
            {c.dates && (
              <div class="p-4 rounded-xl bg-[var(--color-bg-accent)]">
                <p class="text-sm font-semibold text-[var(--color-heading)] mb-2">{page.calendarLabel}</p>
                <div class="text-sm text-[var(--color-text)] space-y-1">
                  {splitLines(c.dates).map((line) => (
                    <p>{line}</p>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
        <ContactCTA label={page.ctaLabel} />
      </div>
    </section>
  )}

  <!-- 5. FAQ -->
  <FaqSection title={page.faqSectionTitle} items={faqItems} ctaLabel={page.ctaLabel} />

  <!-- 6. Cross-links -->
  {page.crossLinksText && (
    <CrossLinksSection text={page.crossLinksText} excludeHref="/ateliers-reguliers/" />
  )}
</BaseLayout>
