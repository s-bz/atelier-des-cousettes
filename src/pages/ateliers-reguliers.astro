---
import ContentPage from '../components/ContentPage.astro';
import { reader } from '../utils/reader';

const page = await reader.singletons.ateliersReguliers.read();
if (!page) throw new Error('Ateliers réguliers content not found');
const contentNode = page.content ? await page.content() : null;
const siteUrl = Astro.site?.toString();
---

<ContentPage
  title={page.title}
  subtitle={page.subtitle}
  seoDescription={page.seoDescription}
  contentNode={contentNode}
  coverImage={page.coverImage ?? undefined}
>
  <Fragment slot="page-head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Ateliers de couture réguliers",
      "description": "Ateliers de couture réguliers à Revel et Verdalle dans le Tarn, tous niveaux, petits groupes, de septembre à juin.",
      "provider": { "@id": `${siteUrl}#organization` },
      "areaServed": { "@type": "AdministrativeArea", "name": "Tarn" },
      "serviceType": "Cours de couture",
      "offers": [
        { "@type": "Offer", "name": "Atelier 2h (une séance)", "price": "25", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Forfait mensuel 1 atelier/mois", "price": "33", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Forfait mensuel 2 ateliers/mois", "price": "55", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Ateliers enfants (mensuel)", "price": "30", "priceCurrency": "EUR" }
      ]
    }).replace(/<\//g, '<\\/')} />
  </Fragment>
</ContentPage>
