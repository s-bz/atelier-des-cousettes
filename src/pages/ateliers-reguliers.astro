---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AtelierCard from '../components/AtelierCard.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { reader } from '../utils/reader';
import { resolveImageUrl } from '../utils/images';
import { toSlug } from '../utils/strings';

const page = await reader.singletons.ateliersReguliers.read();
if (!page) throw new Error('Ateliers réguliers content not found');

const settings = await reader.singletons.siteSettings.read();
const siteUrl = Astro.site?.origin;

// OG image
const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const ogImage = await resolveImageUrl(page.coverImage, coverGlob, Astro.site);

// Schema offers
const offers = (page.schemaOffers ?? []).map((o) => ({
  "@type": "Offer" as const,
  "name": o.name,
  "price": Number(o.price),
  "priceCurrency": "EUR",
}));

// FAQ schema
const faqItems = page.faqItems ?? [];
const faqSchema = faqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
} : null;

// Group creneaux
const creneaux = page.creneaux ?? [];
const groups = [
  { id: 'revel-adultes', label: 'Revel — Adultes' },
  { id: 'revel-enfants', label: 'Revel — Enfants' },
  { id: 'verdalle', label: 'Verdalle' },
] as const;
const groupedCreneaux = groups
  .map((g) => ({ ...g, items: creneaux.filter((c) => c.group === g.id) }))
  .filter((g) => g.items.length > 0);
const groupLabels = Object.fromEntries(groups.map((g) => [g.id, g.label]));

---

<BaseLayout title={page.title} description={page.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
          { "@type": "ListItem", "position": 2, "name": page.title }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": page.title,
        "description": page.seoDescription,
        "url": new URL(Astro.url.pathname, Astro.site).toString(),
        "dateModified": new Date().toISOString().split('T')[0],
        "author": {
          "@type": "Person",
          "name": settings?.authorName,
          "jobTitle": settings?.authorJobTitle,
          "url": `${siteUrl}/la-couturiere/`,
          "sameAs": settings?.facebookUrl ? [settings.facebookUrl] : []
        },
        "isPartOf": { "@id": `${siteUrl}/#website` }
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "name": page.title,
        "description": page.seoDescription,
        "provider": { "@id": `${siteUrl}/#organization` },
        "areaServed": { "@type": "AdministrativeArea", "name": "Tarn" },
        "serviceType": "Cours de couture",
        "offers": offers
      },
      ...(faqSchema ? [faqSchema] : [])
    ]).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={page.title} subtitle={page.subtitle} coverImage={page.coverImage ?? undefined} />

  <!-- 2. Introduction -->
  {page.introduction && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)]">{page.introduction}</p>
        <ContactCTA label={page.ctaLabel || undefined} />
      </div>
    </section>
  )}

  <!-- 3. Quick nav + Créneau cards grouped -->
  {groupedCreneaux.length > 0 && (
    <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-6" style="font-family: var(--font-heading);">
          {page.creneauxSectionTitle || 'Nos créneaux'}
        </h2>

        {/* Pill navigation */}
        <nav class="flex flex-wrap justify-center gap-3 mb-10">
          {groupedCreneaux.map((g) => (
            <a
              href={`#${g.id}`}
              class="inline-block px-5 py-2 rounded-[var(--radius-button)] text-sm font-medium border-2 border-[var(--color-button)] text-[var(--color-button)] hover:bg-[var(--color-button)] hover:text-white transition-colors"
            >
              {g.label}
            </a>
          ))}
        </nav>

        {/* Cards by group */}
        {groupedCreneaux.map((g) => (
          <div id={g.id} class="scroll-mt-24 mb-12 last:mb-0">
            <h3 class="text-xl font-bold text-[var(--color-heading)] mb-6" style="font-family: var(--font-heading);">
              {g.label}
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {g.items.map((c) => (
                <AtelierCard
                  name={c.name}
                  location={c.location}
                  day={c.day}
                  time={c.time}
                  price={c.price}
                  anchorId={`detail-${toSlug(c.name)}`}
                  note={c.note || undefined}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- 4. Créneau details -->
  {creneaux.length > 0 && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 space-y-16">
        {creneaux.map((c) => (
          <div id={`detail-${toSlug(c.name)}`} class="scroll-mt-24">
            <h2 class="text-xl md:text-2xl font-bold text-[var(--color-heading)] mb-2" style="font-family: var(--font-heading);">
              {c.name}
              <span class="ml-2 text-base font-medium text-[var(--color-button)]">{c.day} &middot; {c.time}</span>
            </h2>
            <p class="text-sm text-[var(--color-text-light)] mb-4">{groupLabels[c.group] || c.location}</p>
            {c.priceDetails && (
              <div class="prose mb-4">
                {c.priceDetails.split('\n\n').map((para) => (
                  <p>{para}</p>
                ))}
              </div>
            )}
            {c.dates && (
              <div class="p-4 rounded-xl bg-[var(--color-bg-accent)]">
                <p class="text-sm font-semibold text-[var(--color-heading)] mb-2">Calendrier :</p>
                <div class="text-sm text-[var(--color-text)] space-y-1">
                  {c.dates.split('\n').map((line) => (
                    <p>{line}</p>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
        <ContactCTA label={page.ctaLabel || undefined} />
      </div>
    </section>
  )}

  <!-- 5. FAQ -->
  {faqItems.length > 0 && (
    <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-10" style="font-family: var(--font-heading);">
          {page.faqSectionTitle || 'Questions fréquentes'}
        </h2>
        <div class="space-y-6">
          {faqItems.map((item) => (
            <div>
              <h3 class="text-lg font-semibold text-[var(--color-heading)]" style="font-family: var(--font-heading);">
                {item.question}
              </h3>
              <p class="mt-2 text-[var(--color-text)] leading-relaxed">{item.answer}</p>
            </div>
          ))}
        </div>
        <ContactCTA label={page.ctaLabel || undefined} />
      </div>
    </section>
  )}

  <!-- 6. Cross-links -->
  {page.crossLinksText && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)]">{page.crossLinksText}</p>
        <div class="mt-6 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/stages-thematiques" class="text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors">
            Stages thématiques &rarr;
          </a>
          <a href="/un-apres-midi-couture" class="text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors">
            Un après-midi couture &rarr;
          </a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
