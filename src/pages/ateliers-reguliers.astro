---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import DetailCard from '../components/DetailCard.astro';
import ContactCTA from '../components/ContactCTA.astro';
import FaqSection from '../components/FaqSection.astro';
import { reader } from '../utils/reader';
import { resolveImageUrl } from '../utils/images';
import { toSlug } from '../utils/strings';
import { buildServicePageSchemas } from '../utils/schema';
import { ATELIER_GROUPS, ATELIER_GROUP_LABELS } from '../utils/ateliers';
import { SERVICE_LINKS } from '../utils/nav';

const page = await reader.singletons.ateliersReguliers.read();
if (!page) throw new Error('Ateliers réguliers content not found');

const settings = await reader.singletons.siteSettings.read();
const siteUrl = Astro.site?.origin ?? '';

// OG image
const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const ogImage = await resolveImageUrl(page.coverImage, coverGlob, Astro.site);

const faqItems = page.faqItems ?? [];
const schemas = buildServicePageSchemas({
  title: page.title,
  seoDescription: page.seoDescription,
  pageUrl: new URL(Astro.url.pathname, Astro.site).toString(),
  siteUrl,
  settings,
  offers: page.schemaOffers ?? [],
  faqItems,
});

// Group creneaux
const creneaux = page.creneaux ?? [];
const groupedCreneaux = ATELIER_GROUPS
  .map((g) => ({ ...g, items: creneaux.filter((c) => c.group === g.id) }))
  .filter((g) => g.items.length > 0);

const crossLinks = SERVICE_LINKS.filter((l) => l.href !== '/ateliers-reguliers');
---

<BaseLayout title={page.title} description={page.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemas).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={page.title} subtitle={page.subtitle} coverImage={page.coverImage ?? undefined} />

  <!-- 2. Introduction -->
  {page.introduction && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)]">{page.introduction}</p>
        <ContactCTA label={page.ctaLabel || undefined} />
      </div>
    </section>
  )}

  <!-- 3. Quick nav + Créneau cards grouped -->
  {groupedCreneaux.length > 0 && (
    <section class="bg-[var(--color-bg-accent)] py-16 md:py-20">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-6" style="font-family: var(--font-heading);">
          {page.creneauxSectionTitle || 'Nos créneaux'}
        </h2>

        {/* Pill navigation */}
        <nav class="flex flex-wrap justify-center gap-3 mb-10">
          {groupedCreneaux.map((g) => (
            <a
              href={`#${g.id}`}
              class="inline-block px-5 py-2 rounded-[var(--radius-button)] text-sm font-medium border-2 border-[var(--color-button)] text-[var(--color-button)] hover:bg-[var(--color-button)] hover:text-white transition-colors"
            >
              {g.label}
            </a>
          ))}
        </nav>

        {/* Cards by group */}
        {groupedCreneaux.map((g) => (
          <div id={g.id} class="scroll-mt-24 mb-12 last:mb-0">
            <h3 class="text-xl font-bold text-[var(--color-heading)] mb-6" style="font-family: var(--font-heading);">
              {g.label}
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {g.items.map((c) => (
                <DetailCard
                  name={c.name}
                  anchorId={`detail-${toSlug(c.name)}`}
                  primaryBadge={c.price}
                  details={[`${c.day} \u00B7 ${c.time}`, c.location]}
                  note={c.note || undefined}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- 4. Créneau details -->
  {creneaux.length > 0 && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 space-y-16">
        {creneaux.map((c) => (
          <div id={`detail-${toSlug(c.name)}`} class="scroll-mt-24">
            <h2 class="text-xl md:text-2xl font-bold text-[var(--color-heading)] mb-2" style="font-family: var(--font-heading);">
              {c.name}
              <span class="ml-2 text-base font-medium text-[var(--color-button)]">{c.day} &middot; {c.time}</span>
            </h2>
            <p class="text-sm text-[var(--color-text-light)] mb-4">{/* Keystatic types c.group as string; cast is safe because options are derived from ATELIER_GROUPS */}
            {ATELIER_GROUP_LABELS[c.group as keyof typeof ATELIER_GROUP_LABELS] || c.location}</p>
            {c.priceDetails && (
              <div class="prose mb-4">
                {c.priceDetails.split('\n\n').map((para) => (
                  <p>{para}</p>
                ))}
              </div>
            )}
            {c.dates && (
              <div class="p-4 rounded-xl bg-[var(--color-bg-accent)]">
                <p class="text-sm font-semibold text-[var(--color-heading)] mb-2">Calendrier :</p>
                <div class="text-sm text-[var(--color-text)] space-y-1">
                  {c.dates.split('\n').map((line) => (
                    <p>{line}</p>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
        <ContactCTA label={page.ctaLabel || undefined} />
      </div>
    </section>
  )}

  <!-- 5. FAQ -->
  <FaqSection title={page.faqSectionTitle || 'Questions fréquentes'} items={faqItems} ctaLabel={page.ctaLabel || undefined} />

  <!-- 6. Cross-links -->
  {page.crossLinksText && (
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-base md:text-lg leading-relaxed text-[var(--color-text)]">{page.crossLinksText}</p>
        <div class="mt-6 flex flex-col sm:flex-row gap-4 justify-center">
          {crossLinks.map((link) => (
            <a href={link.href} class="text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors">
              {link.label} &rarr;
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
