---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import IntroSection from '../components/IntroSection.astro';
import CrossLinksSection from '../components/CrossLinksSection.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { getPageContext, reader } from '../utils/reader';
import { resolveImage, resolveImageUrl } from '../utils/images';
import { splitParagraphs } from '../utils/strings';
import { buildPageSchemas } from '../utils/schema';

const page = await reader.singletons.couturiere.read();
if (!page) throw new Error('La couturière content not found');

const { settings, siteUrl } = await getPageContext(Astro.site);

const schemas = buildPageSchemas({
  title: page.title,
  seoDescription: page.seoDescription,
  pageUrl: new URL(Astro.url.pathname, Astro.site).toString(),
  siteUrl,
  settings,
});

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const resolvedCover = await resolveImage(page.coverImage, coverGlob);
const ogImage = await resolveImageUrl(page.coverImage, coverGlob, Astro.site);

// Section images
const sectionGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/couturiere/*.{jpg,jpeg,png,webp}');
const sections = page.sections ?? [];
const resolvedSections = await Promise.all(
  sections.map(async (s) => ({
    ...s,
    resolvedImage: await resolveImage(s.image, sectionGlob),
  })),
);

// Track whether the last biography section used accent background,
// so the cross-links section can alternate correctly.
const lastSectionIsEven = resolvedSections.length > 0 && (resolvedSections.length - 1) % 2 === 0;
---

<BaseLayout title={page.title} description={page.seoDescription} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      ...schemas,
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": settings?.authorName,
        "jobTitle": settings?.authorJobTitle,
        "url": `${siteUrl}/la-couturiere/`,
        "worksFor": { "@id": `${siteUrl}/#organization` },
        "knowsAbout": ["couture", "patronage", "surjeteuse", "machine à coudre", "couture flou"],
        "hasCredential": {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "CAP",
          "name": "CAP couture flou"
        },
        "description": page.seoDescription,
        ...(ogImage ? { "image": ogImage } : {}),
        "sameAs": settings?.facebookUrl ? [settings.facebookUrl] : []
      }
    ]).replace(/<\//g, '<\\/')} />
  </Fragment>

  <!-- 1. Hero -->
  <Hero title={page.title} subtitle={page.subtitle} coverImage={resolvedCover ?? undefined} altText={page.coverImageAlt ?? undefined} />

  <!-- 2. Introduction -->
  {page.introduction && (
    <IntroSection text={page.introduction} ctaLabel={page.ctaLabel} />
  )}

  <!-- 3. Biography sections (even index = accent bg) -->
  {resolvedSections.map((section, i) => {
    const isEven = i % 2 === 0;
    const hasImage = !!section.resolvedImage;
    return (
      <section class={isEven ? 'bg-[var(--color-bg-accent)] py-16 md:py-20' : 'py-16 md:py-20'}>
        <div class="max-w-4xl mx-auto px-4">
          <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-8">
            {section.title}
          </h2>
          {hasImage ? (
            <div class={`flex flex-col ${isEven ? 'md:flex-row-reverse' : 'md:flex-row'} gap-8 items-center`}>
              <div class="w-1/3 mx-auto md:mx-0 md:w-1/5 flex-shrink-0">
                <Image
                  src={section.resolvedImage!}
                  alt={section.imageAlt || section.title}
                  widths={[320, 480, 640]}
                  format="webp"
                  quality={80}
                  class="w-full rounded-[var(--radius-xl)]"
                />
              </div>
              <div class="w-full md:w-4/5 prose max-w-none">
                {section.text && splitParagraphs(section.text).map((para) => (
                  <p>{para}</p>
                ))}
              </div>
            </div>
          ) : (
            <div class="prose max-w-3xl mx-auto">
              {section.text && splitParagraphs(section.text).map((para) => (
                <p>{para}</p>
              ))}
              <div class="text-center not-prose">
                <ContactCTA label={page.ctaLabel} />
              </div>
            </div>
          )}
        </div>
      </section>
    );
  })}

  <!-- 4. Cross-links -->
  {page.crossLinksText && (
    <CrossLinksSection
      text={page.crossLinksText}
      title={page.crossLinksSectionTitle}
      class={lastSectionIsEven ? '' : 'bg-[var(--color-bg-accent)]'}
    />
  )}
</BaseLayout>
