---
import ContentPage from '../components/ContentPage.astro';
import { reader } from '../utils/reader';

const page = await reader.singletons.stagesThematiques.read();
if (!page) throw new Error('Stages thématiques content not found');
const contentNode = page.content ? await page.content() : null;
const siteUrl = Astro.site?.origin;

const offers = (page.schemaOffers ?? []).map((o) => ({
  "@type": "Offer",
  "name": o.name,
  "price": Number(o.price),
  "priceCurrency": "EUR",
}));
---

<ContentPage
  title={page.title}
  subtitle={page.subtitle}
  seoDescription={page.seoDescription}
  contentNode={contentNode}
  coverImage={page.coverImage ?? undefined}
>
  <Fragment slot="page-head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": page.title,
      "description": page.seoDescription,
      "provider": { "@id": `${siteUrl}/#organization` },
      "areaServed": { "@type": "AdministrativeArea", "name": "Tarn" },
      "serviceType": "Cours de couture",
      "offers": offers
    }).replace(/<\//g, '<\\/')} />
  </Fragment>
</ContentPage>
