---
import ContentPage from '../components/ContentPage.astro';
import { reader } from '../utils/reader';

const page = await reader.singletons.stagesThematiques.read();
if (!page) throw new Error('Stages thématiques content not found');
const contentNode = page.content ? await page.content() : null;
const siteUrl = Astro.site?.toString();
---

<ContentPage
  title={page.title}
  subtitle={page.subtitle}
  seoDescription={page.seoDescription}
  contentNode={contentNode}
  coverImage={page.coverImage ?? undefined}
>
  <Fragment slot="page-head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Stages thématiques de couture",
      "description": "Stages de couture dans le Tarn : machine à coudre, surjeteuse, patronage, sacs et accessoires.",
      "provider": { "@id": `${siteUrl}#organization` },
      "areaServed": { "@type": "AdministrativeArea", "name": "Tarn" },
      "serviceType": "Cours de couture",
      "offers": [
        { "@type": "Offer", "name": "Initiation machine à coudre", "price": "40", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Stage découverte de la couture", "price": "90", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Stage surjeteuse", "price": "65", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Stage patronage", "price": "40", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Stage banane", "price": "50", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Stage sac et tote bag", "price": "40", "priceCurrency": "EUR" }
      ]
    }).replace(/<\//g, '<\\/')} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Quel est le prix d'un stage de couture ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Les stages varient de 40\u20AC à 90\u20AC selon le contenu et la durée. Le tissu et les fournitures ne sont pas compris." }
        },
        {
          "@type": "Question",
          "name": "Faut-il apporter sa machine à coudre ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Il est préférable d'apprendre sur sa propre machine et de venir avec tous les accessoires et sa notice. Une machine peut être prêtée sur demande." }
        },
        {
          "@type": "Question",
          "name": "Où ont lieu les stages de couture ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Les stages ont lieu à la maison des associations de Revel et à l'atelier de Verdalle, dans le Tarn." }
        }
      ]
    }).replace(/<\//g, '<\\/')} />
  </Fragment>
</ContentPage>
