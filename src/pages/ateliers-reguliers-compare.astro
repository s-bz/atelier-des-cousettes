<!-- Option C: filter script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    let activeDay = 'tous';
    let activeAudience = 'tous';

    const cards = document.querySelectorAll<HTMLElement>('.workshop-card');
    const noResults = document.getElementById('no-results');
    const dayBtns = document.querySelectorAll<HTMLButtonElement>('.filter-day-btn');
    const audienceBtns = document.querySelectorAll<HTMLButtonElement>('.filter-audience-btn');

    function applyFilters() {
      let visible = 0;
      cards.forEach((card) => {
        const day = card.dataset.day || '';
        const audience = card.dataset.audience || '';
        const matchDay = activeDay === 'tous' || day === activeDay;
        const matchAudience = activeAudience === 'tous' || audience === activeAudience;
        const show = matchDay && matchAudience;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }

    function updateBtnStyles(buttons: NodeListOf<HTMLButtonElement>, activeValue: string, dataAttr: string) {
      buttons.forEach((btn) => {
        const val = btn.getAttribute(`data-filter-${dataAttr}`) || '';
        if (val === activeValue) {
          btn.classList.add('bg-[var(--color-bg-dark)]', 'text-white');
          btn.classList.remove('bg-[var(--color-card-bg)]');
        } else {
          btn.classList.remove('bg-[var(--color-bg-dark)]', 'text-white');
          btn.classList.add('bg-[var(--color-card-bg)]');
        }
      });
    }

    dayBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeDay = btn.dataset.filterDay || 'tous';
        updateBtnStyles(dayBtns, activeDay, 'day');
        applyFilters();
      });
    });

    audienceBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeAudience = btn.dataset.filterAudience || 'tous';
        updateBtnStyles(audienceBtns, activeAudience, 'audience');
        applyFilters();
      });
    });
  });
</script>
