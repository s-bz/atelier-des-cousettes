---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleAuthor?: string;
}

const { title, description = "Cours de couture, ateliers et stages dans le Tarn — L'Atelier des Cousettes à Revel et Verdalle", ogImage, noIndex = false, ogType = 'website', articlePublishedTime, articleAuthor } = Astro.props;
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalURL = new URL(pathname, Astro.site);
const fullTitle = title === "L'Atelier des Cousettes" ? title : `${title} | L'Atelier des Cousettes`;
const resolvedOgImage = ogImage || new URL('/og-default.jpg', Astro.site).toString();
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="robots" content={noIndex ? 'noindex, follow' : 'index, follow'} />

    <!-- Preconnect hints -->
    <link rel="preconnect" href="https://img.youtube.com" />
    <link rel="dns-prefetch" href="https://img.youtube.com" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="L'Atelier des Cousettes" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <title>{fullTitle}</title>
    <slot name="head" />

    <script async src="https://tally.so/widgets/embed.js"></script>

    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-S5FPS810M8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-S5FPS810M8');
    </script>

    <Analytics />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Floating contact button (links to /contact, upgraded to Tally popup if script loads) -->
    <a
      href="/contact/"
      data-tally-fallback
      aria-label="Nous contacter"
      class="floating-contact-btn fixed bottom-6 right-6 z-50 flex items-center gap-2 px-5 py-3 rounded-[var(--radius-button)] bg-[var(--color-button)] text-white font-medium text-sm shadow-lg transition-all hover:bg-[var(--color-button-hover)] hover:scale-105 hover:shadow-xl no-underline"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
      <span class="hidden sm:inline">Nous contacter</span>
    </a>

    <!-- Upgrade contact links to Tally popups if script loaded -->
    <script is:inline>
      (function() {
        if (typeof Tally === 'undefined') return;
        var els = document.querySelectorAll('[data-tally-fallback]');
        for (var i = 0; i < els.length; i++) {
          var el = els[i];
          el.setAttribute('data-tally-open', 'wvGxVA');
          el.setAttribute('data-tally-align-left', '1');
          el.setAttribute('data-tally-hide-title', '1');
          el.setAttribute('data-tally-overlay', '1');
          el.setAttribute('data-tally-emoji-text', '🧵');
          el.setAttribute('data-tally-emoji-animation', 'wave');
          el.setAttribute('data-tally-auto-close', '2000');
          el.removeAttribute('href');
          el.removeAttribute('data-tally-fallback');
          el.style.cursor = 'pointer';
        }
        Tally.loadEmbeds();
      })();
    </script>

    <!-- Markdoc YouTube embed: click-to-play -->
    <script>
      document.addEventListener('click', (e) => {
        const container = (e.target as HTMLElement).closest('.markdoc-youtube');
        if (!container) return;
        const videoId = container.getAttribute('data-video-id');
        if (!videoId) return;
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${encodeURIComponent(videoId)}?autoplay=1`;
        iframe.title = 'YouTube video';
        iframe.setAttribute('frameborder', '0');
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;
        container.replaceChildren(iframe);
      });
    </script>
  </body>
</html>
