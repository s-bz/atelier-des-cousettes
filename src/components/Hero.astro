---
import { Image, getImage } from 'astro:assets';
import { resolveImage } from '../utils/images';

interface Props {
  title: string;
  subtitle?: string;
  coverImage?: string;
  altText?: string;
  flush?: boolean;
}

const { title, subtitle, coverImage: coverImageRaw, altText, flush = false } = Astro.props;

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const resolvedCover = await resolveImage(coverImageRaw, coverGlob);

// Generate optimized image URL for preloading
const preloadImage = resolvedCover
  ? await getImage({ src: resolvedCover, width: 640, format: 'webp', quality: 60 })
  : null;
---

{preloadImage && (
  <link rel="preload" as="image" type="image/webp" href={preloadImage.src} />
)}

{resolvedCover ? (
  <section class={`relative h-64 md:h-80 overflow-hidden bg-[#2c2420] ${flush ? '' : 'mb-8 md:mb-12'}`}>
    <Image
      src={resolvedCover}
      alt={altText || `Image de couverture — ${title}`}
      class="absolute inset-0 w-full h-full object-cover object-center"
      widths={[640, 1024, 1440]}
      sizes="100vw"
      format="webp"
      quality={60}
      height={480}
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-black/50" />
    <div class="relative h-full flex flex-col items-center justify-center px-4 text-center">
      <h1 class="hero-title text-3xl md:text-5xl font-medium leading-tight text-white" style="font-family: var(--font-heading);">{title}</h1>
      {subtitle && (
        <p class="hero-subtitle mt-3 text-lg md:text-xl text-white/90">{subtitle}</p>
      )}
    </div>
  </section>
) : (
  <section class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-medium leading-tight" style="font-family: var(--font-heading);">{title}</h1>
      {subtitle && (
        <p class="mt-4 text-lg md:text-xl text-[var(--color-text)]">{subtitle}</p>
      )}
    </div>
  </section>
)}

<style>
  .hero-title {
    color: white !important;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.7), 0 0 2px rgba(0, 0, 0, 0.5);
  }
  .hero-subtitle {
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7), 0 0 2px rgba(0, 0, 0, 0.4);
  }
</style>
