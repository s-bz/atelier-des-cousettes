---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  subtitle?: string;
  coverImage?: string;
}

const { title, subtitle, coverImage } = Astro.props;

// Dynamically import the cover image from src/assets
const coverImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/*.{jpg,jpeg,png,webp}');
const resolvedCover = coverImage ? await coverImages[`/src/assets/images/covers/${coverImage}`]?.() : null;
---

{resolvedCover ? (
  <section class="relative h-64 md:h-80 overflow-hidden">
    <Image
      src={resolvedCover.default}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      widths={[640, 1024, 1440]}
      sizes="100vw"
      format="webp"
      quality={80}
    />
    <div class="absolute inset-0 bg-black/40" />
    <div class="relative h-full flex flex-col items-center justify-center px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-black leading-tight text-white drop-shadow-lg" style="font-family: var(--font-heading);">{title}</h1>
      {subtitle && (
        <p class="mt-3 text-lg md:text-xl text-white/90 drop-shadow">{subtitle}</p>
      )}
    </div>
  </section>
) : (
  <section class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-black leading-tight" style="font-family: var(--font-heading);">{title}</h1>
      {subtitle && (
        <p class="mt-4 text-lg md:text-xl text-[var(--color-text)]">{subtitle}</p>
      )}
    </div>
  </section>
)}
