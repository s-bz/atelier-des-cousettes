---
interface Props {
  title: string;
  subtitle?: string;
  coverImage?: string;
}

const { title, subtitle, coverImage } = Astro.props;
---

{coverImage ? (
  <section class="relative h-64 md:h-80 overflow-hidden">
    <img
      src={coverImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/40" />
    <div class="relative h-full flex flex-col items-center justify-center px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-black leading-tight text-white drop-shadow-lg" style="font-family: var(--font-heading);">{title}</h1>
      {subtitle && (
        <p class="mt-3 text-lg md:text-xl text-white/90 drop-shadow">{subtitle}</p>
      )}
    </div>
  </section>
) : (
  <section class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-black leading-tight" style="font-family: var(--font-heading);">{title}</h1>
      {subtitle && (
        <p class="mt-4 text-lg md:text-xl text-[var(--color-text)]">{subtitle}</p>
      )}
    </div>
  </section>
)}
