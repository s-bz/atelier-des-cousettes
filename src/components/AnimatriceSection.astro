---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  text: string;
  image?: ImageMetadata;
  imageAlt: string;
  linkLabel: string;
  linkHref: string;
}

const { title, text, image, imageAlt, linkLabel, linkHref } = Astro.props;
const paragraphs = text.split(/\n\s*\n/).map(p => p.replace(/\n/g, ' ').trim()).filter(Boolean);
---

<div class="max-w-4xl mx-auto px-4">
  <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
    {image && (
      <div class="w-2/3 mx-auto md:mx-0 md:w-1/3 flex-shrink-0">
        <Image
          src={image}
          alt={imageAlt || title}
          class="rounded-xl w-full max-h-80 object-cover"
          format="webp"
          quality={80}
          widths={[320, 480, 640]}
          sizes="(max-width: 768px) 66vw, 33vw"
        />
      </div>
    )}
    <div class={image ? 'w-full md:w-2/3' : 'w-full max-w-2xl mx-auto text-center'}>
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)]" style="font-family: var(--font-heading);">
        {title}
      </h2>
      {paragraphs.map((p, i) => (
        <p class={`${i === 0 ? 'mt-4' : 'mt-3'} text-[var(--color-text)] leading-relaxed`}>{p}</p>
      ))}
      <a
        href={linkHref}
        class="mt-6 inline-block text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors"
      >
        {linkLabel} &rarr;
      </a>
    </div>
  </div>
</div>
