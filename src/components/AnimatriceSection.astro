---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  text: string;
  image?: ImageMetadata;
  imageAlt: string;
  linkLabel: string;
  linkHref: string;
}

const { title, text, image, imageAlt, linkLabel, linkHref } = Astro.props;
---

<div class="max-w-4xl mx-auto px-4">
  <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
    {image && (
      <div class="w-full md:w-2/5 flex-shrink-0">
        <Image
          src={image}
          alt={imageAlt || title}
          class="rounded-xl w-full h-auto object-cover"
          format="webp"
          quality={80}
          widths={[320, 480, 640]}
          sizes="(max-width: 768px) 100vw, 40vw"
        />
      </div>
    )}
    <div class={image ? 'w-full md:w-3/5' : 'w-full max-w-2xl mx-auto text-center'}>
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)]" style="font-family: var(--font-heading);">
        {title}
      </h2>
      <p class="mt-4 text-[var(--color-text)] leading-relaxed">{text}</p>
      <a
        href={linkHref}
        class="mt-6 inline-block text-sm font-semibold text-[var(--color-link)] hover:text-[var(--color-button)] transition-colors"
      >
        {linkLabel} &rarr;
      </a>
    </div>
  </div>
</div>
