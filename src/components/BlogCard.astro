---
import { formatFrenchDate } from '../utils/strings';

interface Props {
  title: string;
  slug: string;
  publishDate: string;
  description: string;
  readMoreLabel: string;
}

const { title, slug, publishDate, description, readMoreLabel } = Astro.props;

const formattedDate = formatFrenchDate(publishDate);
---

<a href={`/blog/${slug}`} class="group block rounded-lg bg-white dark:bg-[var(--color-card-bg)] p-6 transition-all" style="box-shadow: var(--shadow-ring), var(--shadow-whisper);" aria-label={title}>
  <time datetime={publishDate} class="text-sm text-[var(--color-text-light)]">{formattedDate}</time>
  <h2 class="mt-2 text-xl font-medium leading-tight group-hover:text-[var(--color-link)] transition-colors">
    {title}
  </h2>
  {description && (
    <p class="mt-2 text-sm text-[var(--color-text)] line-clamp-2 md:line-clamp-3">{description}</p>
  )}
  <span class="mt-4 inline-block text-sm font-semibold text-[var(--color-link)] group-hover:text-[var(--color-button)] transition-colors">
    {readMoreLabel} &rarr;
  </span>
</a>

<style>
  a.group:hover {
    box-shadow: var(--shadow-ring), var(--shadow-whisper);
  }
</style>
