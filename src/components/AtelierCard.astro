---
interface Props {
  name: string;
  location: string;
  day: string;
  time: string;
  price: string;
  anchorId: string;
  note?: string;
}

const { name, location, day, time, price, anchorId, note } = Astro.props;
---

<a href={`#${anchorId}`} class="atelier-card group flex flex-col rounded-xl bg-white dark:bg-[var(--color-card-bg)] overflow-hidden transition-all p-5 h-full">
  <h3 class="text-lg font-semibold text-[var(--color-heading)]" style="font-family: var(--font-heading);">
    {name}
  </h3>
  <div class="mt-2 flex-1 space-y-1 text-sm text-[var(--color-text)]">
    <p>{day} &middot; {time}</p>
    <p>{location}</p>
    {note && <p class="italic text-[var(--color-text-light)]">{note}</p>}
  </div>
  <div class="mt-3 text-sm font-medium text-[var(--color-button)]">
    {price}
  </div>
</a>

<style>
  .atelier-card {
    box-shadow: var(--shadow-ring), var(--shadow-whisper);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .atelier-card:hover {
    box-shadow: var(--shadow-ring), 0 4px 12px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }
</style>
