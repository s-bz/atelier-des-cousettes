---
import { reader } from '../utils/reader';
import { navLinks } from '../utils/navLinks';

const settings = await reader.singletons.siteSettings.read();
const navLeft = navLinks.slice(0, 3);
const navRight = navLinks.slice(3);
---

<footer class="bg-[var(--color-bg-dark)]">
  <div class="max-w-5xl mx-auto px-4 py-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 text-sm">
    <!-- Contact + Social -->
    <div>
      <h2 class="font-medium mb-3 text-[var(--color-bg-accent)]">Contact</h2>
      <ul class="space-y-2 text-[var(--color-dark-text)]">
        {settings?.email && (
          <li>
            <a href={`mailto:${settings.email}`} class="hover:text-white transition-colors">
              📧 {settings.email}
            </a>
          </li>
        )}
        {settings?.phones?.map((phone) => (
          <li>
            <a href={`tel:${phone.replace(/[-.\s]/g, '')}`} class="hover:text-white transition-colors">
              📱 {phone}
            </a>
          </li>
        ))}
        {settings?.facebookUrl && (
          <li>
            <a
              href={settings.facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition-colors inline-flex items-center gap-1.5"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
          </li>
        )}
        {settings?.googleBusinessUrl && (
          <li>
            <a
              href={settings.googleBusinessUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition-colors inline-flex items-center gap-1.5"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 92 92"><path d="M46 2C27.7 2 13 16.7 13 35c0 25.4 33 55 33 55s33-29.6 33-55C79 16.7 64.3 2 46 2zm0 46c-7.2 0-13-5.8-13-13s5.8-13 13-13 13 5.8 13 13-5.8 13-13 13z"/></svg>
              Google
            </a>
          </li>
        )}
      </ul>
    </div>

    <!-- Navigation — split into 2 sub-columns -->
    <div class="lg:col-span-2">
      <h2 class="font-medium mb-3 text-[var(--color-bg-accent)]">Navigation</h2>
      <nav aria-label="Navigation pied de page">
        <ul class="grid grid-cols-2 gap-x-8 gap-y-2 text-[var(--color-dark-text)]">
          {navLeft.map((link) => (
            <li><a href={link.href} class="hover:text-white transition-colors">{link.label}</a></li>
          ))}
          {navRight.map((link) => (
            <li><a href={link.href} class="hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>

  <div class="border-t border-[rgba(255,255,255,0.1)] py-4 text-center text-xs text-[var(--color-dark-text)]">
    &copy; <span id="footer-year"></span> {settings?.siteName || "L'Atelier des Cousettes"} · <a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a>
  </div>

  <script>
    document.getElementById('footer-year')!.textContent = String(new Date().getFullYear());
  </script>
</footer>
