---
import { reader } from '../utils/reader';

interface Props {
  label?: string;
}

const settings = await reader.singletons.siteSettings.read();
const { label = settings?.defaultCtaLabel } = Astro.props;
---

<div class="mt-8 mb-8 text-center not-prose">
  <a
    href="/contact/"
    data-tally-fallback
    class="cta-button inline-block px-8 py-3 rounded-[var(--radius-button)] font-medium text-sm bg-[var(--color-button)] text-white transition-all hover:bg-[var(--color-button-hover)] hover:scale-[1.02] no-underline"
  >
    {label}
  </a>
</div>

<style>
  .cta-button {
    color: white !important;
    text-decoration: none !important;
  }
</style>
