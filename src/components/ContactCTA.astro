---
import { reader } from '../utils/reader';

interface Props {
  label?: string;
  url?: string;
}

const settings = await reader.singletons.siteSettings.read();
const { label = "Demande d'information", url = settings?.contactFormUrl || '#' } = Astro.props;
---

<div class="mt-8 text-center">
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block px-8 py-3 rounded-[var(--radius-button)] font-medium text-sm bg-[var(--color-button)] transition-all hover:bg-[var(--color-button-hover)] hover:scale-[1.02] no-underline"
    style="color: #ffffff; text-decoration: none;"
  >
    {label}
  </a>
</div>
