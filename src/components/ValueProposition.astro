---
interface Props {
  title: string;
  items: ReadonlyArray<{ title: string; description: string }>;
}

const { title, items } = Astro.props;
---

<div class="max-w-4xl mx-auto px-4">
  <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] text-center mb-10" style="font-family: var(--font-heading);">
    {title}
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
    {items.map((item) => (
      <div class="rounded-xl bg-[var(--color-card-bg)] p-6" style="box-shadow: var(--shadow-ring);">
        <h3 class="text-base font-semibold text-[var(--color-heading)]" style="font-family: var(--font-heading);">
          {item.title}
        </h3>
        <p class="mt-2 text-sm text-[var(--color-text)] leading-relaxed">{item.description}</p>
      </div>
    ))}
  </div>
</div>
