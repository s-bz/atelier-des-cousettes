---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Markdoc from '@markdoc/markdoc';

interface Props {
  title: string;
  subtitle?: string;
  seoDescription: string;
  contentNode: { node: import('@markdoc/markdoc').Node } | null;
  showContactCTA?: boolean;
  coverImage?: string;
}

const { title, subtitle, seoDescription, contentNode, showContactCTA = true, coverImage } = Astro.props;
const transformed = contentNode ? Markdoc.transform(contentNode.node) : null;
const renderedContent = transformed ? Markdoc.renderers.html(transformed) : '';
const siteUrl = Astro.site?.origin;
---

<BaseLayout title={title} description={seoDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": title }
      ]
    }).replace(/<\//g, '<\\/')} />
  </Fragment>
  <Hero title={title} subtitle={subtitle} coverImage={coverImage} />

  <div class="max-w-3xl mx-auto px-4 prose">
    <Fragment set:html={renderedContent} />

    {showContactCTA && <ContactCTA />}
  </div>
</BaseLayout>
