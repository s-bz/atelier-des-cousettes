---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Markdoc from '@markdoc/markdoc';
import { resolveImageUrl } from '../utils/images';
import { reader } from '../utils/reader';

interface Props {
  title: string;
  subtitle?: string;
  seoDescription: string;
  contentNode: { node: import('@markdoc/markdoc').Node } | null;
  showContactCTA?: boolean;
  coverImage?: string;
  coverImageAlt?: string;
  contentClass?: string;
  noIndex?: boolean;
}

const { title, subtitle, seoDescription, contentNode, showContactCTA = true, coverImage, coverImageAlt, contentClass, noIndex = false } = Astro.props;
const transformed = contentNode ? Markdoc.transform(contentNode.node) : null;
const renderedContent = transformed ? Markdoc.renderers.html(transformed) : '';
const siteUrl = Astro.site?.origin;
const settings = await reader.singletons.siteSettings.read();

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const ogImage = await resolveImageUrl(coverImage, coverGlob, Astro.site);
---

<BaseLayout title={title} description={seoDescription} ogImage={ogImage} noIndex={noIndex}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
          { "@type": "ListItem", "position": 2, "name": title }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": title,
        "description": seoDescription,
        "url": new URL(Astro.url.pathname, Astro.site).toString(),
        "author": {
          "@type": "Person",
          "name": settings?.authorName,
          "jobTitle": settings?.authorJobTitle,
          "url": `${siteUrl}/la-couturiere/`,
          "sameAs": settings?.facebookUrl ? [settings.facebookUrl] : []
        },
        "isPartOf": { "@id": `${siteUrl}/#website` }
      }
    ]).replace(/<\//g, '<\\/')} />
    <slot name="page-head" />
  </Fragment>
  <Hero title={title} subtitle={subtitle} coverImage={coverImage} altText={coverImageAlt} />

  <div class={`${contentClass || 'max-w-3xl'} mx-auto px-4 prose overflow-visible`}>
    <Fragment set:html={renderedContent} />

    {showContactCTA && <ContactCTA />}
  </div>
</BaseLayout>
