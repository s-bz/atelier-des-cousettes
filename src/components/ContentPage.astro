---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { resolveImage, resolveImageUrl } from '../utils/images';
import { getPageContext } from '../utils/reader';
import { renderMarkdoc } from '../utils/markdoc-components';
import { buildPageSchemas } from '../utils/schema';

interface Props {
  title: string;
  subtitle?: string;
  seoDescription: string;
  contentNode: { node: import('@markdoc/markdoc').Node } | null;
  showContactCTA?: boolean;
  coverImage?: string;
  coverImageAlt?: string;
  contentClass?: string;
  noIndex?: boolean;
}

const { title, subtitle, seoDescription, contentNode, showContactCTA = true, coverImage, coverImageAlt, contentClass, noIndex = false } = Astro.props;
const renderedContent = renderMarkdoc(contentNode?.node);
const { settings, siteUrl } = await getPageContext(Astro.site);

const coverGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/covers/**/*.{jpg,jpeg,png,webp}');
const resolvedCover = await resolveImage(coverImage, coverGlob);
const ogImage = await resolveImageUrl(coverImage, coverGlob, Astro.site);

const schemas = buildPageSchemas({
  title,
  seoDescription,
  pageUrl: new URL(Astro.url.pathname, Astro.site).toString(),
  siteUrl,
  settings,
});
---

<BaseLayout title={title} description={seoDescription} ogImage={ogImage} noIndex={noIndex}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemas).replace(/<\//g, '<\\/')} />
    <slot name="page-head" />
  </Fragment>
  <Hero title={title} subtitle={subtitle} coverImage={resolvedCover ?? undefined} altText={coverImageAlt} />

  <div class={`${contentClass || 'max-w-3xl'} mx-auto px-4 prose overflow-visible`}>
    <Fragment set:html={renderedContent} />

    {showContactCTA && <ContactCTA />}
  </div>
</BaseLayout>
