---
import { Image } from 'astro:assets';

interface Props {
  label: string;
  href: string;
  resolvedImage?: ImageMetadata;
  imageAlt: string;
  priceRange?: string;
  shortDescription?: string;
}

const { label, href, resolvedImage, imageAlt, priceRange, shortDescription } = Astro.props;
const safeHref = href?.startsWith('/') ? href : '#';
---

<a href={safeHref} class="service-card group block rounded-xl bg-white dark:bg-[var(--color-card-bg)] overflow-hidden transition-all" aria-label={label}>
  {resolvedImage && (
    <Image
      src={resolvedImage}
      alt={imageAlt || label}
      class="w-full h-48 sm:h-56 object-cover group-hover:opacity-90 transition-opacity"
      format="webp"
      quality={80}
      widths={[320, 480, 640]}
      sizes="(max-width: 640px) 100vw, 33vw"
    />
  )}
  <div class="p-4">
    <h3 class="text-lg font-semibold text-[var(--color-heading)]">
      {label}
    </h3>
    {shortDescription && (
      <p class="mt-1 text-sm text-[var(--color-text)] line-clamp-2">{shortDescription}</p>
    )}
    {priceRange && (
      <span class="mt-3 inline-block text-sm font-medium text-[var(--color-button)]">
        {priceRange}
      </span>
    )}
  </div>
</a>

<style>
  .service-card {
    box-shadow: var(--shadow-ring), var(--shadow-whisper);
  }
  .service-card:hover {
    box-shadow: var(--shadow-ring), 0 4px 12px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }
</style>
