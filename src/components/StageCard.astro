---
interface Props {
  name: string;
  price: string;
  duration: string;
  shortDescription: string;
  anchorId: string;
}

const { name, price, duration, shortDescription, anchorId } = Astro.props;
---

<a href={`#${anchorId}`} class="stage-card group flex flex-col rounded-xl bg-white dark:bg-[var(--color-card-bg)] overflow-hidden transition-all p-5 h-full">
  <h3 class="text-lg font-semibold text-[var(--color-heading)]" style="font-family: var(--font-heading);">
    {name}
  </h3>
  <p class="mt-1 text-sm text-[var(--color-text)] flex-1">{shortDescription}</p>
  <div class="mt-3 flex items-center gap-3 text-sm font-medium">
    <span class="text-[var(--color-button)]">{price}</span>
    <span class="text-[var(--color-text-light)]">{duration}</span>
  </div>
</a>

<style>
  .stage-card {
    box-shadow: var(--shadow-ring), var(--shadow-whisper);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .stage-card:hover {
    box-shadow: var(--shadow-ring), 0 4px 12px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }
</style>
