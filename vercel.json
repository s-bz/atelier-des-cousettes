{
  "redirects": [
    { "source": "/mentions-lgales", "destination": "/mentions-legales", "permanent": true },
    { "source": "/stages-thmatiques", "destination": "/stages-thematiques", "permanent": true },
    { "source": "/ateliers-rguliers", "destination": "/ateliers-reguliers", "permanent": true },
    { "source": "/cours-particuliers", "destination": "/un-apres-midi-couture", "permanent": true },
    { "source": "/la-couturire", "destination": "/la-couturiere", "permanent": true },
    { "source": "/mes-crations", "destination": "/mes-creations", "permanent": true },
    { "source": "/sitemap.xml", "destination": "/sitemap-index.xml", "permanent": true }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://img.youtube.com https://*.ytimg.com; frame-src https://www.youtube-nocookie.com; connect-src 'self' https://va.vercel-scripts.com; font-src 'self'" }
      ]
    }
  ]
}
